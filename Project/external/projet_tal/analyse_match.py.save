import re
import json
import csv

#Fonction nettoyage

def nettoyer_texte(texte):
    texte = texte.lower()
    texte = re.sub(r"[^\w\s\-:]", "", texte)
    texte = re.sub(r"(.)\1{2,}", r"\1", texte)
    return texte
# Detection automatiquement les evenement

def detecter_evenement(titre):
    texte = nettoyer_texte(titre)

    if "post match" in texte or "post-match" in texte:
        return "FIN_MATCH"

    elif "match thread" in texte:
        return "MATCH_THREAD"

    elif "var" in texte:
        return "VAR"

    elif "penalty" in texte or "pens" in texte:
        return "PENALTY"

    elif "goal" in texte or "but" in texte:
        return "BUT"

    elif "red card" in texte or "carton rouge" in texte:
        return "CARTON_ROUGE"

    else:
        return "AUTRE"
# Extraire automatiquement le score

def extraire_score(titre):
    score = re.search(r"\b\d+\s*[-:]\s*\d+\b", titre)

    if score:
        return score.group()

    return None

# Ouvrir le fichier JSON

with open("period_debug_galata_liverpool_20260310_1779694004.json", "r", encoding="utf-8") as fichier :
    data = json.load(fichier)

# Afficher les clés principales 

print("Fichier chargé avec succès !")
print("Les grandes parties du fichier sont :")
print(data.keys())

posts = data["posts"]

summary = data["summary"]
print("\nResumé du dataset :")
print("posts rècupérés :", summary["posts_fetched"])
print("Commentaires scannés :", summary["comments_scanned"])
print("Commentaires dans les fenêtres du match :", summary["comments_in_period_windows"])
print("Taux de correspondance :", summary["match_rate_percent"], "%")

per_period_counts = summary["per_period_counts"]

print("\nCommentaires par période du match :")

print("\nNettoyage des titres :")

for post in posts[:10]:
    titre_original = post["title"]
    titre_nettoye = nettoyer_texte(titre_original)

    print("Original :", titre_original)
    print("Nettoyé  :", titre_nettoye)
    print("-" * 60)
# Detection Automatique 

print("\nDétection des événements :")

for post in posts[:20]:
    titre = post["title"]
    evenement = detecter_evenement(titre)

    print("Titre :", titre)
    print("Événement détecté :", evenement)
    print("-" * 60)
# Teste sur les postes

print("\nExtraction des scores :")

for post in posts[:30]:
    titre = post["title"]
    score = extraire_score(titre)

    if score:
        print("Titre :", titre)
        print("Score détecté :", score)
        print("-" * 60)
# Constructruire une table de resultats tal

resultats = []

for post in posts:
    titre = post["title"]
    heure = post["created_time"]

    evenement = detecter_evenement(titre)
    score = extraire_score(titre)

    ligne = {
        "heure": heure,
        "evenement": evenement,
        "score": score,
        "titre": titre
    }

    resultats.append(ligne)

print("\nRésultats TAL :")

for ligne in resultats[:30]:
    print(ligne["heure"], "|", ligne["evenement"], "|", ligne["score"], "|", ligne["titre"])
# Compter les évenements détectés

compteurs = {}

for ligne in resultats:
    evenement = ligne["evenement"]

    if evenement not in compteurs:
        compteurs[evenement] = 0

    compteurs[evenement] += 1

print("\nNombre d'événements détectés :")

for evenement, nombre in compteurs.items():
    print(evenement, ":", nombre)
# Exporter les resultats TAL en CSV

nom_sortie = "resultats_tal.csv"

with open(nom_sortie, "w", encoding="utf-8", newline="") as fichier_csv:
    colonnes = ["heure", "evenement", "score", "titre"]

    writer = csv.DictWriter(fichier_csv, fieldnames=colonnes)

    writer.writeheader()

    for ligne in resultats:
        writer.writerow(ligne)

print("\nFichier CSV créé :", nom_sortie)
# Créer une timeline sociae

resultats_tries = sorted(resultats, key=lambda x: x["heure"])

print("\nTimeline sociale détectée :")

for ligne in resultats_tries:
    if ligne["evenement"] != "AUTRE":
        print(
            ligne["heure"],
            "|",
            ligne["evenement"],
            "|",
nements détectés :")

